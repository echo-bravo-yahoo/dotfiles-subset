    ],
    "deny": []
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "c hook session-start",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "c hook session-end"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "c hook notification-waiting",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash|Read|Write|Edit|WebFetch|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/migrate-permissions.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Write|Edit|WebFetch|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "cc-allow --hook"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-config.sh"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/deny-update-config.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "c hook notification-waiting",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "c hook user-prompt",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "c hook post-bash",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash|Read|Write|Edit|WebFetch|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/cc-allow-postuse",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/validate-config.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "c hook stop",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "refreshInterval": 60000
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "cc-query@cc-query-dev": true,
    "frontend-design@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "cc-replay@cc-replay": true
  },
  "extraKnownMarketplaces": {
    "cc-replay": {
      "source": {
        "source": "github",
        "repo": "vlognow/cc-replay"
      }
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Lying"
    ]
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
